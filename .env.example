# Copy to `.env` for local use.
APP_ENV=local
LOG_LEVEL=INFO

# Storage
DB_PATH=./artifacts/reports.sqlite
ARTIFACTS_DIR=./artifacts
ARTIFACT_STORE=local
ARTIFACT_STORE_BUCKET=
ARTIFACT_STORE_PREFIX=clinical-ai-reliability-lab
ARTIFACT_STORE_S3_ENDPOINT_URL=
ARTIFACT_STORE_S3_REGION=

# Provider selection
LLM_PROVIDER=mock

# Optional: enable OTLP export to a local collector (e.g., SigNoz)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_SERVICE_NAME=clinical-ai-reliability-lab
